datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MENTOR
  MENTEE
}

enum MemberRole {
  MENTOR
  MENTEE
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewAction {
  APPROVE
  REJECT
  COMMENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum ActivityEvent {
  PROJECT_CREATED
  TASK_CREATED
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REJECTED
  MEMBER_INVITED
  MEMBER_JOINED
  COMMENT_ADDED
}

enum NotificationType {
  TASK_ASSIGNED
  REVIEW_COMPLETED
  INVITE_ACCEPTED
  COMMENT_RECEIVED
  DEADLINE_REMINDER
}

model Organization {
  id         String        @id @default(uuid())
  name       String
  logoUrl    String?
  slug       String        @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  users      User[]
  invitations Invitation[]
  projects   Project[]
  activityLogs ActivityLog[]
}

model User {
  id                 String               @id @default(uuid())
  organizationId     String
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name               String
  email              String               @unique
  passwordHash       String
  role               UserRole
  avatarUrl          String?
  isActive           Boolean              @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  invitationsSent    Invitation[]         @relation("InvitedBy")
  projectsCreated    Project[]            @relation("ProjectCreator")
  projectMemberships ProjectMember[]
  tasksCreated       Task[]               @relation("TaskCreator")
  tasksAssigned      Task[]               @relation("TaskAssignee")
  taskSubmissions    TaskSubmission[]
  taskFeedbacks      TaskFeedback[]
  attachments        Attachment[]
  activityLogs       ActivityLog[]
  notifications      Notification[]
  passwordResetTokens PasswordResetToken[]
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById    String
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  email          String
  role           UserRole
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status         InviteStatus @default(PENDING)
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
}

model Project {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User            @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)
  name           String
  description    String?
  status         ProjectStatus   @default(ACTIVE)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  members        ProjectMember[]
  tasks          Task[]
  invitations    Invitation[]
  activityLogs   ActivityLog[]
}

model ProjectMember {
  id        String     @id @default(uuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MemberRole
  joinedAt  DateTime   @default(now())

  @@unique([projectId, userId])
}

model Task {
  id             String           @id @default(uuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignedToId   String
  assignedTo     User             @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  instructions   String?
  status         TaskStatus       @default(PENDING)
  priority       TaskPriority     @default(MEDIUM)
  deadline       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  submissions    TaskSubmission[]
  feedbacks      TaskFeedback[]
  attachments    Attachment[]
  activityLogs   ActivityLog[]
}

model TaskSubmission {
  id          String         @id @default(uuid())
  taskId      String
  task        Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submittedBy String
  user        User           @relation(fields: [submittedBy], references: [id], onDelete: Cascade)
  content     String
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime       @default(now())
  feedbacks   TaskFeedback[]
  attachments Attachment[]
}

model TaskFeedback {
  id           String          @id @default(uuid())
  taskId       String
  task         Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submissionId String?
  submission   TaskSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  reviewerId   String
  reviewer     User            @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  comment      String
  action       ReviewAction
  createdAt    DateTime        @default(now())
}

model Attachment {
  id           String          @id @default(uuid())
  taskId       String
  task         Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submissionId String?
  submission   TaskSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User            @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime        @default(now())
}

model ActivityLog {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorId        String
  actor          User          @relation(fields: [actorId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId         String?
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  eventType      ActivityEvent
  metadata       String?       // SQLite lacks Native JSONB, stored as stringified JSON
  createdAt      DateTime      @default(now())
}

model Notification {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          NotificationType
  title         String
  body          String
  referenceId   String?
  referenceType String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}
